page {
  height: 100%;
  background: #1a1a2e;
}

.page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #1a1a2e;
}

/* 审核占位层 */
.fallback-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.fallback-text {
  color: #ffffff;
  font-size: 80rpx;
  font-weight: bold;
  letter-spacing: 10rpx;
}

.canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  z-index: 1;
  transition: height 0.3s ease;
}

.canvas--full {
  height: 100vh;
}

.slider_wrapper {
  padding: 0 15rpx;
}

.custom-button {
  background: blue;
  color: #FFF;
  box-sizing: border-box;
  border-radius: 50%;
  font-size: 30rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.effect-picker {
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

/* ========== 遮罩 ========== */

.mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0);
  z-index: 20;
}

/* ========== 设置面板 ========== */

.settings-panel {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 55vh;
  background: #fff;
  z-index: 21;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -6rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.settings-panel--show {
  transform: translateY(0);
}

.settings-panel__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.settings-panel__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.settings-panel__close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1;
}

/* ========== 标签栏 ========== */

.settings__tabs {
  display: flex;
  flex-shrink: 0;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
  transition: color 0.2s;
}

.tab-item--active {
  color: #667eea;
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #667eea;
}

/* ========== 可滚动内容区 ========== */

.settings-panel__bd {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx 40rpx;
  box-sizing: border-box;
}

.tab-pane {
  width: 100%;
}

/* ========== 设置行 ========== */

.set-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.set-row__label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  min-width: 120rpx;
}

.set-row van-slider {
  flex: 1;
}

.custom-btn {
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

/* ========== 特效选择弹出层 */
.effect-sheet-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.effect-sheet {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.effect-sheet--show {
  transform: translateY(0);
}

.effect-sheet__title {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.effect-sheet__list {
  max-height: 480rpx;
  padding: 8rpx 0;
}

.effect-sheet__item {
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f5f5f5;
}

.effect-sheet__item--active {
  color: #667eea;
  font-weight: 600;
  background: #f0f0ff;
}

.effect-sheet__cancel {
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  border-top: 8rpx solid #f5f5f5;
}
