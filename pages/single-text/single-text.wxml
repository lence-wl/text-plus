<view class="page">
	<!-- 返回按钮 -->
	<back-btn />
	<!-- 审核占位层：Canvas 就绪后隐藏 -->
	<view class="fallback-layer" wx:if="{{!canvasReady}}">
		<text class="fallback-text">{{ config.text }}</text>
	</view>
	<!-- Canvas 始终全屏，设置面板浮在其上方 -->
	<canvas type="2d" id="myCanvas" class="canvas canvas--full"
	bindtouchstart="touchEvent" bindtouchmove="touchEvent" bindtouchend="touchEvent" bindtouchcancel="touchEvent"></canvas>

	<!-- 遮罩 -->
	<view class="mask" wx:if="{{showSettings}}" catchtap="closeSettings"></view>

	<!-- 设置面板 -->
	<view class="settings-panel {{showSettings ? 'settings-panel--show' : ''}}">
		<view class="settings-panel__hd">
			<text class="settings-panel__title">设置</text>
			<text class="settings-panel__close" bindtap="closeSettings">✕</text>
		</view>

		<!-- 标签栏 -->
		<view class="settings__tabs">
			<view class="tab-item {{activeTab === 'content' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="content">内容</view>
			<view class="tab-item {{activeTab === 'style' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="style">样式</view>
			<view class="tab-item {{activeTab === 'font' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="font">字体</view>
      <view class="tab-item {{activeTab === 'effect' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="effect">特效</view>
			<view class="tab-item {{activeTab === 'scroll' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="scroll">滚动</view>
		</view>

		<scroll-view class="settings-panel__bd" scroll-y>

			<!-- ========== 内容 ========== -->
			<view class="tab-pane" wx:if="{{activeTab === 'content'}}">
				<view class="set-row set-row--input">
					<van-field style="width:100%;" value="{{ config.text }}"
					type="textarea"
					rows="3"
					bind:blur="onTextBlur" placeholder="请输入文字内容" custom-style="background:#f5f5f5;border-radius:8rpx;height:100rpx;" />
				</view>
				<view class="tool-btns">
					<view class="tool-btn tool-btn--clear" bindtap="onClearText">清空</view>
					<view class="tool-btn tool-btn--history" bindtap="onShowHistory">历史</view>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-3429c9c03c2605b4"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<!-- ========== 样式 ========== -->
			<view class="tab-pane" wx:if="{{activeTab === 'style'}}">
				<view class="set-row">
					<text class="set-row__label">字体大小</text>
					<van-slider min="60" max="300" step="1" value="{{ config.fontSize }}" use-button-slot bind:change="onFontSizeConfirm">
						<view class="custom-btn" slot="button">{{ config.fontSize }}</view>
					</van-slider>
				</view>
				<view class="set-row">
					<text class="set-row__label">文字加粗</text>
					<van-switch checked="{{ config.fontWeight === 'bold' }}" bind:change="onFontWeightChange" />



				</view>
				<view class="set-row">
					<text class="set-row__label">背景颜色</text>
					<view style="flex:1;"><ColorPicker colorList="{{[config.bgColor]}}" bind:colorChange="handleBgColorChange" /></view>
				</view>
			<view class="set-row">
					<ad-custom
						unit-id="adunit-876e2216578e8903"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<!-- ========== 特效 ========== -->
			<view class="tab-pane" wx:if="{{activeTab === 'effect'}}">
				<view class="set-row">
					<text class="set-row__label">特效选择</text>
					<view class="effect-picker" hover-class="effect-picker--hover" catch:tap="onEffectPickerTap">{{ currentEffectName }}</view>
				</view>

				<!-- 抖动模式 -->
				<block wx:if="{{ config.effectMode === 'glitch' }}">
					<view class="set-row">
						<text class="set-row__label">字体颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.redColor, config.cyanColor]}}" bind:colorChange="handleGlitchColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">抖动频率</text>
						<van-slider min="1" max="20" step="1" value="{{ config.glitchInterval }}" use-button-slot bind:change="onGlitchIntervalChange">
							<view class="custom-btn" slot="button">{{ config.glitchInterval }}帧</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">抖动幅度</text>
						<van-slider min="1" max="20" step="1" value="{{ config.glitchOffsetAmplitude }}" use-button-slot bind:change="onGlitchOffsetAmplitudeChange">
							<view class="custom-btn" slot="button">{{ config.glitchOffsetAmplitude }}px</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">基础偏移</text>
						<van-slider min="0" max="10" step="0.5" value="{{ config.glitchBaseOffset }}" use-button-slot bind:change="onGlitchBaseOffsetChange">
							<view class="custom-btn" slot="button">{{ config.glitchBaseOffset }}px</view>
						</van-slider>
					</view>
				</block>

				<!-- 发光模式 -->
				<block wx:if="{{ config.effectMode === 'glow' }}">
					<view class="set-row">
						<text class="set-row__label">字体颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.glowColor]}}" bind:colorChange="handleGlowColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">发光强度</text>
						<van-slider min="1" max="20" step="1" value="{{ config.glowOuterStrength }}" use-button-slot bind:change="onGlowStrengthChange">
							<view class="custom-btn" slot="button">{{ config.glowOuterStrength }}</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">发光距离</text>
						<van-slider min="5" max="30" step="1" value="{{ config.glowDistance }}" use-button-slot bind:change="onGlowDistanceChange">
							<view class="custom-btn" slot="button">{{ config.glowDistance }}px</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">呼吸速度</text>
						<van-slider min="0.5" max="5" step="0.5" value="{{ config.glowBreathSpeed }}" use-button-slot bind:change="onGlowBreathSpeedChange">
							<view class="custom-btn" slot="button">{{ config.glowBreathSpeed }}</view>
						</van-slider>
					</view>
				</block>

				<!-- 霓虹灯模式 -->
				<block wx:if="{{ config.effectMode === 'neon' }}">
					<view class="set-row">
						<text class="set-row__label">内核颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.neonCoreColor]}}" bind:colorChange="handleNeonCoreColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">中层颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.neonColor]}}" bind:colorChange="handleNeonColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">外层颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.neonGlowColor]}}" bind:colorChange="handleNeonGlowColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">发光强度</text>
						<van-slider min="1" max="10" step="1" value="{{ config.neonStrength }}" use-button-slot bind:change="onNeonStrengthChange">
							<view class="custom-btn" slot="button">{{ config.neonStrength }}</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">闪烁速度</text>
						<van-slider min="0.5" max="5" step="0.5" value="{{ config.neonFlickerSpeed }}" use-button-slot bind:change="onNeonFlickerSpeedChange">
							<view class="custom-btn" slot="button">{{ config.neonFlickerSpeed }}</view>
						</van-slider>
					</view>
				</block>

				<!-- 彩虹模式 -->
				<block wx:if="{{ config.effectMode === 'rainbow' }}">
					<view class="set-row">
						<text class="set-row__label">彩虹颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{config.rainbowColors}}" bind:colorChange="handleRainbowColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">渐变方向</text>
						<view class="effect-picker" hover-class="effect-picker--hover" catch:tap="onGradientDirPickerTap">{{ rainbowGradientTypeLabel }}</view>
					</view>
					<view class="set-row">
						<text class="set-row__label">阴影效果</text>
						<van-switch checked="{{ config.rainbowDropShadow }}" bind:change="onRainbowDropShadowChange" />
					</view>
				</block>

				<!-- 波浪模式 -->
				<block wx:if="{{ config.effectMode === 'wave' }}">
					<view class="set-row">
						<text class="set-row__label">字体颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.waveColor]}}" bind:colorChange="handleWaveColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">波浪幅度</text>
						<van-slider min="5" max="50" step="1" value="{{ config.waveAmplitude }}" use-button-slot bind:change="onWaveAmplitudeChange">
							<view class="custom-btn" slot="button">{{ config.waveAmplitude }}px</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">波浪频率</text>
						<van-slider min="0.1" max="2" step="0.1" value="{{ config.waveFrequency }}" use-button-slot bind:change="onWaveFrequencyChange">
							<view class="custom-btn" slot="button">{{ config.waveFrequency }}</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">波浪速度</text>
						<van-slider min="0.5" max="10" step="0.5" value="{{ config.waveSpeed }}" use-button-slot bind:change="onWaveSpeedChange">
							<view class="custom-btn" slot="button">{{ config.waveSpeed }}</view>
						</van-slider>
					</view>
				</block>

				<!-- 色彩循环模式 -->
				<block wx:if="{{ config.effectMode === 'colorCycle' }}">
					<view class="set-row">
						<text class="set-row__label">循环颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{ config.colorCycleColors }}" bind:colorChange="handleColorCycleColorsChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">循环速度</text>
						<van-slider min="0.5" max="10" step="0.5" value="{{ config.colorCycleSpeed }}" use-button-slot bind:change="onColorCycleSpeedChange">
							<view class="custom-btn" slot="button">{{ config.colorCycleSpeed }}</view>
						</van-slider>
					</view>
				</block>

				<!-- 缩放脉冲模式 -->
				<block wx:if="{{ config.effectMode === 'scalePulse' }}">
					<view class="set-row">
						<text class="set-row__label">字体颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{ [config.scalePulseColor] }}" bind:colorChange="handleScalePulseColorChange" /></view>
					</view>
					<view class="set-row">
						<text class="set-row__label">最小缩放</text>
						<van-slider min="0.5" max="1" step="0.1" value="{{ config.scalePulseMinScale }}" use-button-slot bind:change="onScalePulseMinScaleChange">
							<view class="custom-btn" slot="button">{{ config.scalePulseMinScale }}</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">最大缩放</text>
						<van-slider min="1" max="2" step="0.1" value="{{ config.scalePulseMaxScale }}" use-button-slot bind:change="onScalePulseMaxScaleChange">
							<view class="custom-btn" slot="button">{{ config.scalePulseMaxScale }}</view>
						</van-slider>
					</view>
					<view class="set-row">
						<text class="set-row__label">脉冲速度</text>
						<van-slider min="0.5" max="10" step="0.5" value="{{ config.scalePulseSpeed }}" use-button-slot bind:change="onScalePulseSpeedChange">
							<view class="custom-btn" slot="button">{{ config.scalePulseSpeed }}</view>
						</van-slider>
					</view>
				</block>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-c8df033167be76e3"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<!-- ========== 滚动 ========== -->
			<view class="tab-pane" wx:if="{{activeTab === 'scroll'}}">
				<view class="set-row">
					<text class="set-row__label">滚动速度</text>
					<van-slider min="1" max="10" step="0.5" value="{{ config.scrollSpeed }}" use-button-slot bind:change="onScrollSpeedChange">
						<view class="custom-btn" slot="button">{{ config.scrollSpeed }}</view>
					</van-slider>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-66b2f271d3be3299"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>


      <!-- ========== 字体 ========== -->
      <view class="tab-pane" wx:if="{{activeTab === 'font'}}">
        <view class="fonts">
          <view class="font-card {{!config.fontFamily ? 'font-card--on' : ''}}"
            bindtap="onFontSelect" data-font="">
            <text class="font-card__preview">默认</text>
          </view>
          <block wx:for="{{fontList}}" wx:for-item="f" wx:key="name">
            <view class="font-card {{config.fontFamily===f.name?'font-card--on':''}}"
              bindtap="onFontSelect" data-font="{{f.name}}">
              <text class="font-card__preview" style="font-family:{{f.name}}">{{f.previewText}}</text>
            </view>
          </block>
        </view>
        <text style="display:none">{{_previewVersion}}</text>
      </view>
		</scroll-view>
	</view>

  <!-- 渐变方向选择弹出层 -->
		<view class="effect-sheet-mask" wx:if="{{showGradientSheet}}" catch:tap="onGradientSheetClose"></view>
		<view class="effect-sheet {{showGradientSheet ? 'effect-sheet--show' : ''}}" wx:if="{{showGradientSheet}}">
			<view class="effect-sheet__title">选择渐变方向</view>
			<scroll-view class="effect-sheet__list" scroll-y>
				<view
					wx:for="{{gradientOptions}}"
					wx:key="value"
					class="effect-sheet__item {{item.value === config.rainbowGradientType ? 'effect-sheet__item--active' : ''}}"
					data-value="{{item.value}}"
					catch:tap="onGradientSheetSelect"
				>{{item.text}}</view>
			</scroll-view>
			<view class="effect-sheet__cancel" catch:tap="onGradientSheetClose">取消</view>
		</view>




<!-- 特效选择弹出层 -->
	<view class="effect-sheet-mask" wx:if="{{showEffectSheet}}" catch:tap="onEffectSheetClose"></view>
	<view class="effect-sheet {{showEffectSheet ? 'effect-sheet--show' : ''}}" wx:if="{{showEffectSheet}}">
		<view class="effect-sheet__title">选择特效</view>
		<scroll-view class="effect-sheet__list" scroll-y>
			<view
				wx:for="{{effectOptions}}"
				wx:key="key"
				class="effect-sheet__item {{item.value === config.currentEffect ? 'effect-sheet__item--active' : ''}}"
				data-index="{{index}}"
				catch:tap="onEffectSheetSelect"
			>{{item.text}}</view>
		</scroll-view>
		<view class="effect-sheet__cancel" catch:tap="onEffectSheetClose">取消</view>
	</view>

  <!-- 历史记录弹出层 -->
  <view class="effect-sheet-mask" wx:if="{{showHistorySheet}}" catch:tap="onHistoryClose"></view>
  <view class="effect-sheet {{showHistorySheet ? 'effect-sheet--show' : ''}}" wx:if="{{showHistorySheet}}">
    <view class="effect-sheet__title">历史记录</view>
    <scroll-view class="effect-sheet__list" scroll-y>
      <view wx:for="{{historyList}}" wx:key="time" class="history-item">
        <text class="history-item__text" catch:tap="onHistorySelect" data-index="{{index}}">{{item.displayText}}</text>
        <view class="history-item__del" catch:tap="onHistoryDelete" data-index="{{index}}">删除</view>
      </view>
      <view class="effect-sheet__empty" wx:if="{{historyList.length === 0}}">暂无历史记录</view>
    </scroll-view>
    <view class="effect-sheet__cancel" catch:tap="onHistoryClose">取消</view>
  </view>
</view>
