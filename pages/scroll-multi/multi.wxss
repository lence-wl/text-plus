page {
  height: 100%;
  background: #1a1a2e;
}

.page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ========== 悬浮按钮 ========== */

/* ========== 滚动区域 ========== */

.scroll-stage {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.scroll-stage--landscape {
  width: 100vh;
  height: 100vw;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(90deg);
  transform-origin: center center;
}

.scroll-stage--mirror {
  transform: scaleX(-1);
}

.scroll-stage--landscape.scroll-stage--mirror {
  transform: translate(-50%, -50%) rotate(90deg) scaleX(-1);
}

.scroll-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-weight: bold;
  will-change: transform;
}

.scroll-block {
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
  white-space: pre-wrap;
  word-break: break-word;
}

.scroll-block--glow {
  text-shadow: 0 0 var(--glow-blur, 12px) var(--glow-color, #ff66ff),
               0 0 calc(var(--glow-blur, 12px) * 2) var(--glow-color, #ff66ff);
}

/* ========== 遮罩 ========== */

.mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0);
  z-index: 20;
}

/* ========== 设置面板 ========== */

.settings-panel {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 55vh;
  background: #fff;
  z-index: 21;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -6rpx 32rpx rgba(0, 0, 0, 0.12);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
	box-sizing: border-box;
}

.settings-panel--show {
  transform: translateY(0);
}

.settings-panel__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
  box-sizing: border-box;
}

.settings-panel__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.settings-panel__close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1;
}

/* ========== 标签栏（固定） ========== */

.settings__tabs {
  display: flex;
  flex-shrink: 0;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
  transition: color 0.2s;
}

.tab-item--active {
  color: #667eea;
  font-weight: 600;
}

.tab-item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #667eea;
}
.tab-pane{
	width: 100%;
}

/* ========== 可滚动内容区 ========== */

.settings-panel__bd {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx 40rpx;
	box-sizing: border-box;
}

/* ========== 设置项：左标签 + 右控件 ========== */

.set-textarea {
  background: #f5f5f5;
  color: #333;
  font-size: 26rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  line-height: 1.6;
	max-height: 300rpx;
}

.set-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.set-row__label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  min-width: 120rpx;
}

.set-row__input {
  flex: 1;
  background: #f5f5f5;
  color: #333;
  font-size: 26rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  text-align: right;
  box-sizing: border-box;
}

.set-row van-slider {
  flex: 1;
}

.custom-btn {
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

/* ========== 对齐 / 方向选择 ========== */

.align-picker {
  display: flex;
  gap: 12rpx;
}

.align-opt {
  text-align: center;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.align-opt--active {
  color: #fff;
  background: #667eea;
}
.van-field__control--textarea{
min-height: 100px !important;
}

/* ========== 工具按钮（清空 / 历史） ========== */

.tool-btns {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
}

.tool-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.tool-btn--clear {
  color: #e74c3c;
  background: #fdf0ef;
  border: 2rpx solid #f5c6cb;
}

.tool-btn--clear:active {
  background: #f9d6d5;
}

.tool-btn--history {
  color: #667eea;
  background: #f0f2ff;
  border: 2rpx solid #c3cbf5;
}

.tool-btn--history:active {
  background: #e0e4ff;
}

/* ========== 历史记录项 ========== */

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item__text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.history-item__del {
  flex-shrink: 0;
  margin-left: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #e74c3c;
  border: 1rpx solid #e74c3c;
  border-radius: 6rpx;
}

.history-item__del:active {
  background: #fdf0ef;
}

/* ========== 弹出层（复用 single-text 的 effect-sheet 样式） ========== */

.effect-sheet-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.effect-sheet {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.effect-sheet--show {
  transform: translateY(0);
}

.effect-sheet__title {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.effect-sheet__list {
  max-height: 480rpx;
  padding: 8rpx 0;
}

.effect-sheet__cancel {
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  border-top: 8rpx solid #f5f5f5;
}

.effect-sheet__empty {
  padding: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

/* ========== 字体卡片 ========== */
.font-lang-tabs { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.font-lang-tab { padding: 10rpx 28rpx; border-radius: 20rpx; font-size: 26rpx; background: #f0f0f0; color: #666; }
.font-lang-tab--on { background: #1677ff; color: #fff; }
.fonts { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 8rpx 0; justify-content: flex-start; }
.font-card { width: 30%; padding: 24rpx 8rpx; border: 2rpx solid #e0e0e0; border-radius: 12rpx; text-align: center; box-sizing: border-box; background: #fff; }
.font-card:active { background: #f5f5f5; }
.font-card--on { border-color: #1677ff; background: #e6f4ff; }
.font-card__preview { font-size: 36rpx; display: block; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: #333; }

.mirror-hint {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0 16rpx;
  line-height: 1.5;
}

