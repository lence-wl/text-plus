<view class="page">
	<!-- 返回按钮 -->
	<back-btn />

	<!-- 滚动区域（双击打开设置） -->
	<view class="scroll-stage {{config.screenDirection === 'landscape' ? 'scroll-stage--landscape' : ''}} {{config.mirrorEnabled ? 'scroll-stage--mirror' : ''}}" style="background: {{config.bgColor}};" bindtouchstart="touchEvent" bindtouchend="touchEvent" bindtouchcancel="touchEvent">
		<view class="scroll-track" style="transform: translateY({{scrollY}}px);font-size: {{config.fontSize}}px;color: {{config.textColor}};{{fontStyle}}">
			<view class="scroll-block {{config.glowEnabled ? 'scroll-block--glow' : ''}}" style="text-align: {{config.textAlign}};line-height: {{config.lineHeight}}; --glow-blur: {{config.glowBlur}}px; --glow-color: {{config.glowColor}};">
				{{rawText}}
			</view>
		</view>
	</view>

	<!-- 遮罩 -->
	<view class="mask" wx:if="{{showSettings}}" catchtap="closeSettings"></view>

	<!-- 设置面板 -->
	<view class="settings-panel {{showSettings ? 'settings-panel--show' : ''}}">
		<view class="settings-panel__hd">
			<text class="settings-panel__title">设置</text>
			<text class="settings-panel__close" bindtap="closeSettings">✕</text>
		</view>

		<!-- 标签栏 -->
		<view class="settings__tabs">
			<view class="tab-item {{activeTab === 'content' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="content">内容</view>
			<view class="tab-item {{activeTab === 'style' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="style">样式</view>
      <view class="tab-item {{activeTab === 'font' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="font">字体</view>
			<view class="tab-item {{activeTab === 'color' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="color">颜色</view>
			<view class="tab-item {{activeTab === 'glow' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="glow">发光</view>
			<view class="tab-item {{activeTab === 'screen' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="screen">滚动</view>
			<view class="tab-item {{activeTab === 'mirror' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="mirror">镜像</view>
		</view>

		<!-- 可滚动内容 -->
		<scroll-view class="settings-panel__bd" scroll-y>

			<view class="tab-pane" wx:if="{{activeTab === 'content'}}">
				<van-field type="textarea" value="{{rawText}}" placeholder="输入文字，换行即分行..." custom-style="background:#f5f5f5;border-radius:8rpx;min-height:100px;font-size:28rpx;" bind:blur="onTextBlur" />
				<view class="tool-btns">
					<view class="tool-btn tool-btn--clear" bindtap="onClearText">清空</view>
					<view class="tool-btn tool-btn--history" bindtap="onShowHistory">历史</view>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-09650eed41b2c79b"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<view class="tab-pane" wx:if="{{activeTab === 'style'}}">
				<view class="set-row">
					<text class="set-row__label">字体大小</text>
					<van-slider min="20" max="120" step="2" value="{{config.fontSize}}" use-button-slot bind:change="onFontSizeChange">
						<view class="custom-btn" slot="button">{{config.fontSize}}</view>
					</van-slider>
				</view>


				<view class="set-row">
					<text class="set-row__label">行高</text>
					<van-slider min="1" max="3" step="0.1" value="{{config.lineHeight}}" use-button-slot bind:change="onLineHeightChange">
						<view class="custom-btn" slot="button">{{config.lineHeight}}</view>
					</van-slider>
				</view>
				<view class="set-row">
					<text class="set-row__label">对齐方式</text>
					<view class="align-picker">
						<view class="align-opt {{config.textAlign === 'left' ? 'align-opt--active' : ''}}" bindtap="onTextAlignChange" data-align="left">左对齐</view>
						<view class="align-opt {{config.textAlign === 'center' ? 'align-opt--active' : ''}}" bindtap="onTextAlignChange" data-align="center">居中</view>
					</view>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-35f6fb51975ea0ea"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<view class="tab-pane" wx:if="{{activeTab === 'color'}}">
				<view class="set-row">
					<text class="set-row__label">字体颜色</text>
					<view style="flex:1;"><ColorPicker colorList="{{[config.textColor]}}" bind:colorChange="handleTextColorChange" /></view>
				</view>
				<view class="set-row">
					<text class="set-row__label">背景颜色</text>
					<view style="flex:1;"><ColorPicker colorList="{{[config.bgColor]}}" bind:colorChange="handleBgColorChange" /></view>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-609e191ce97caaef"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<view class="tab-pane" wx:if="{{activeTab === 'glow'}}">
				<view class="set-row">
					<text class="set-row__label">发光</text>
					<van-switch checked="{{config.glowEnabled}}" bind:change="onGlowEnabledChange" />
				</view>
				<block wx:if="{{config.glowEnabled}}">
					<view class="set-row">
						<text class="set-row__label">发光强度</text>
						<van-slider min="2" max="40" step="1" value="{{config.glowBlur}}" use-button-slot bind:change="onGlowBlurChange">
							<view class="custom-btn" slot="button">{{config.glowBlur}}</view>
						</van-slider>
					</view>



					<view class="set-row">
						<text class="set-row__label">发光颜色</text>
						<view style="flex:1;"><ColorPicker colorList="{{[config.glowColor]}}" bind:colorChange="handleGlowColorChange" /></view>
					</view>
				</block>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-82b9229cee5b393c"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>

			<view class="tab-pane" wx:if="{{activeTab === 'screen'}}">
				<view class="set-row">
					<text class="set-row__label">滚动速度</text>
					<van-slider min="1" max="10" step="0.5" value="{{config.scrollSpeed}}" use-button-slot bind:change="onScrollSpeedChange">
						<view class="custom-btn" slot="button">{{config.scrollSpeed}}</view>
					</van-slider>
				</view>
				<view class="set-row">
					<text class="set-row__label">滚动方向</text>
					<view class="align-picker">
						<view class="align-opt {{config.screenDirection === 'portrait' ? 'align-opt--active' : ''}}" bindtap="onDirectionChange" data-direction="portrait">竖屏</view>
						<view class="align-opt {{config.screenDirection === 'landscape' ? 'align-opt--active' : ''}}" bindtap="onDirectionChange" data-direction="landscape">横屏</view>
					</view>
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-960d20b8ffa4e8fe"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>



			<!-- ========== 镜像 ========== -->
			<view class="tab-pane" wx:if="{{activeTab === 'mirror'}}">
				<view class="mirror-hint">💡 直播时开启，屏幕中文字就可以正常显示了哦</view>
				<view class="set-row">
					<text class="set-row__label">直播镜像</text>
					<van-switch checked="{{config.mirrorEnabled}}" bind:change="onMirrorChange" />
				</view>
				<view class="set-row">
					<ad-custom
						unit-id="adunit-cc7ea8b53a9a2533"
						bindload="adLoad"
						binderror="adError"
						bindclose="adClose"
						style="width:100%; min-height:200rpx; border-radius:8rpx;"
					></ad-custom>
				</view>
			</view>
      <!-- ========== 字体 ========== -->
      <view class="tab-pane" wx:if="{{activeTab === 'font'}}">
        <view class="font-lang-tabs">
          <view class="font-lang-tab {{fontLangTab === 'zh' ? 'font-lang-tab--on' : ''}}" bindtap="onFontLangTap" data-lang="zh">中文</view>
          <view class="font-lang-tab {{fontLangTab === 'en' ? 'font-lang-tab--on' : ''}}" bindtap="onFontLangTap" data-lang="en">English</view>
        </view>
        <view class="fonts">
          <view class="font-card {{!config.fontFamily ? 'font-card--on' : ''}}"
            bindtap="onFontSelect" data-font="">
            <text class="font-card__preview">默认</text>
          </view>
          <block wx:for="{{fontList}}" wx:for-item="f" wx:key="name">
            <view class="font-card {{config.fontFamily===f.name?'font-card--on':''}}"
              wx:if="{{f.lang === fontLangTab}}"
              bindtap="onFontSelect" data-font="{{f.name}}">
              <text class="font-card__preview" style="font-family:'{{f.name}}'">{{f.previewText}}</text>
            </view>
          </block>
        </view>
        <text style="display:none">{{_previewVersion}}</text>
      </view>
		</scroll-view>
	</view>

  <!-- 历史记录弹出层 -->
  <view class="effect-sheet-mask" wx:if="{{showHistorySheet}}" catch:tap="onHistoryClose"></view>
  <view class="effect-sheet {{showHistorySheet ? 'effect-sheet--show' : ''}}" wx:if="{{showHistorySheet}}">
    <view class="effect-sheet__title">历史记录</view>
    <scroll-view class="effect-sheet__list" scroll-y>
      <view wx:for="{{historyList}}" wx:key="time" class="history-item">
        <text class="history-item__text" catch:tap="onHistorySelect" data-index="{{index}}">{{item.displayText}}</text>
        <view class="history-item__del" catch:tap="onHistoryDelete" data-index="{{index}}">删除</view>
      </view>
      <view class="effect-sheet__empty" wx:if="{{historyList.length === 0}}">暂无历史记录</view>
    </scroll-view>
    <view class="effect-sheet__cancel" catch:tap="onHistoryClose">取消</view>
  </view>

</view>
