/* ========== 页面 ========== */
page { background: #000; }
.page {
  width: 100vw; height: 100vh;
  position: relative; overflow: hidden;
  background: #000;
}

/* ========== Canvas ========== */
.canvas {
  position: absolute; left: 0; top: 0;
  width: 100vw; height: 100vh;
}

/* ========== 底部控制栏 ========== */
.controls {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; flex-direction: column; align-items: center;
  gap: 12rpx; padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

/* ========== 颜色选择行 ========== */
.color-row {
  display: flex; gap: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.06);
}
.color-dot {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.15);
  transition: transform 0.15s, border-color 0.15s;
}
.color-dot:active { transform: scale(1.3); }
.color-dot--active {
  border-color: #fff;
  transform: scale(1.2);
  box-shadow: 0 0 12rpx rgba(255,255,255,0.3);
}

/* ========== 控制行 ========== */
.ctrl-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; flex-wrap: wrap;
}
.ctrl-group {
  display: flex; align-items: center; gap: 8rpx;
}
.ctrl-btn {
  height: 60rpx; padding: 0 18rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.12);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #fff;
  min-width: 60rpx;
  transition: background 0.15s;
}
.ctrl-btn:active { background: rgba(255,255,255,0.28); }
.ctrl-btn--disabled { opacity: 0.3; }
.ctrl-btn--danger { color: #ff6b6b; }
.ctrl-btn--toggle {
  font-size: 22rpx; color: rgba(255,255,255,0.5);
  padding: 0 16rpx; min-width: 56rpx; height: 48rpx;
}
.ctrl-btn--active {
  background: rgba(255,255,255,0.25);
  color: #fff;
}
.ctrl-label {
  font-size: 22rpx; color: rgba(255,255,255,0.7);
  min-width: 40rpx; text-align: center;
}

/* ========== 导出遮罩 ========== */
.export-mask {
  position: fixed; left: 0; top: 0; width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.6); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.export-mask__title { color: #fff; font-size: 32rpx; }
