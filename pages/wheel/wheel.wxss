/* ========== 页面基底 ========== */
page { background: #1a1a2e; }
.page {
  width: 100vw; height: 100vh;
  display: flex; flex-direction: column;
  position: relative; overflow: hidden;
  background: #1a1a2e;
}

/* ========== 画布区 ========== */
.canvas-wrap {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.canvas-wrap canvas {
  width: 620rpx; height: 620rpx;
}

/* ========== 结果展示条 ========== */
.result-bar {
  display: flex; align-items: center; justify-content: center;
  padding: 20rpx 32rpx; flex-shrink: 0;
}
.result-bar__text {
  font-size: 32rpx; color: #f093fb; font-weight: bold;
  letter-spacing: 4rpx;
}
.result-bar__action {
  margin-left: 20rpx; padding: 8rpx 24rpx;
  font-size: 24rpx; color: #667eea;
  border: 2rpx solid #667eea; border-radius: 20rpx;
}
.result-bar__placeholder {
  font-size: 26rpx; color: #555;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  display: flex; gap: 16rpx; padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
.bar-btn {
  flex: 1; padding: 20rpx 0; border-radius: 16rpx;
  text-align: center; font-size: 28rpx; font-weight: 600;
}
.bar-btn--primary {
  background: linear-gradient(135deg, #667eea, #764ba2); color: #fff;
}
.bar-btn--outline {
  background: transparent; color: #667eea;
  border: 2rpx solid #667eea;
}
.bar-btn--danger {
  background: rgba(255,71,87,0.15); color: #ff4757;
}

/* ========== 选项列表 ========== */
.option-list {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 8rpx 32rpx 16rpx; flex-shrink: 0;
  max-height: 180rpx; overflow-y: auto;
}
.option-tag {
  display: flex; align-items: center;
  padding: 8rpx 12rpx 8rpx 20rpx;
  background: rgba(255,255,255,0.08); border-radius: 20rpx;
}
.option-tag__text {
  font-size: 24rpx; color: #ccc; max-width: 120rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.option-tag__del {
  margin-left: 8rpx; width: 32rpx; height: 32rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #888;
}
.option-tag--add {
  border: 2rpx dashed rgba(255,255,255,0.2); background: transparent;
}
.option-tag--add .option-tag__text { color: #667eea; }
.option-tag--input {
  padding: 0; background: transparent;
}
.option-tag__input {
  width: 100rpx; height: 44rpx; font-size: 24rpx; color: #fff;
  background: rgba(255,255,255,0.1); border-radius: 8rpx;
  padding: 0 12rpx; box-sizing: border-box;
}

/* ========== 操作按钮行 ========== */
.action-row {
  display: flex; gap: 16rpx;
  padding: 8rpx 32rpx; flex-shrink: 0;
}
.action-row .bar-btn { font-size: 24rpx; padding: 12rpx 0; }

/* ========== 弹出结果遮罩 ========== */
.result-popup {
  position: fixed; left: 0; top: 0; width: 100vw; height: 100vh;
  background: rgba(0,0,0,0.6); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.result-popup__card {
  background: #1e1e3a; border-radius: 24rpx; padding: 60rpx 80rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.5);
}
.result-popup__emoji { font-size: 80rpx; margin-bottom: 24rpx; }
.result-popup__label { font-size: 26rpx; color: #8890a8; margin-bottom: 12rpx; }
.result-popup__value { font-size: 48rpx; color: #f093fb; font-weight: bold; margin-bottom: 40rpx; }
.result-popup__btn {
  padding: 16rpx 60rpx; background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 40rpx;
}
