page {
  height: 100%;
  background: #1a1a2e;
}

.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #1a1a2e;
  overflow: hidden;
  position: relative;
}

/* ===== 预览区域 ===== */

.preview-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
}

.preview-canvas {
  border-radius: 8rpx;
  box-shadow: 0 0 40rpx rgba(0, 0, 0, 0.3);
}

/* ===== 导出进度遮罩 ===== */

.export-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(26, 26, 46, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.export-mask__title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.export-mask__progress {
  color: #8890a8;
  font-size: 60rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
}

.export-mask__bar {
  width: 60%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
}

.export-mask__fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #f093fb);
  border-radius: 6rpx;
  transition: width 0.2s ease;
}

/* ===== 宫格模式栏 ===== */

.mode-bar {
  width: 100%;
  padding: 12rpx 32rpx 0;
  display: flex;
  gap: 16rpx;
  justify-content: center;
	margin-bottom: 30rpx;
}

.mode-btn {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  transition: all 0.2s;
}

.mode-btn--active {
  background: rgba(102, 126, 234, 0.3);
  color: #ffffff;
}

/* ===== 底部操作栏 ===== */

.bottom-bar {
  width: 100%;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.input-wrap {
  flex: 1;
}

.text-input {
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 0 32rpx;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  line-height: 80rpx;
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.btn-export {
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #667eea, #f093fb);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-export text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
}

.btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ===== 设置面板内滑块按钮 ===== */

.custom-button {
  width: 60rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
}
