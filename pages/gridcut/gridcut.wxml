<view class="page">
  <!-- 预览区域 -->
  <view class="preview-wrap">
    <canvas
      type="2d"
      id="previewCanvas"
      class="preview-canvas"
      style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
      bindtouchstart="touchEvent"
    />

    <!-- 导出进度遮罩 -->
    <view class="export-mask" wx:if="{{isExporting}}">
      <text class="export-mask__title">导出中</text>
      <text class="export-mask__progress">{{exportProgress}} / {{exportTotal}}</text>
      <view class="export-mask__bar">
        <view class="export-mask__fill" style="width: {{exportProgress / exportTotal * 100+'%'}}"></view>
      </view>
    </view>
  </view>

  <!-- 宫格模式 + 单字/多字 -->
  <view class="mode-bar">
    <view class="mode-btn {{!config.multiMode?'mode-btn--active':''}}" bind:tap="onMultiModeToggle">单字</view>
    <view class="mode-btn {{config.multiMode?'mode-btn--active':''}}" bind:tap="onMultiModeToggle">多字</view>
		<view style="width: 40rpx;"></view>
    <view class="mode-btn {{config.gridRows==2&&config.gridCols==2?'mode-btn--active':''}}" bind:tap="onGridMode" data-rows="2" data-cols="2">2×2</view>
    <view class="mode-btn {{config.gridRows==3&&config.gridCols==2?'mode-btn--active':''}}" bind:tap="onGridMode" data-rows="3" data-cols="2">3×2</view>
    <view class="mode-btn {{config.gridRows==2&&config.gridCols==3?'mode-btn--active':''}}" bind:tap="onGridMode" data-rows="2" data-cols="3">2×3</view>
    <view class="mode-btn {{config.gridRows==3&&config.gridCols==3?'mode-btn--active':''}}" bind:tap="onGridMode" data-rows="3" data-cols="3">3×3</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="input-wrap">
      <input
        class="text-input"
        value="{{config.text}}"
        bind:blur="onTextBlur"
        placeholder="{{config.multiMode ? '输入' + (config.gridRows*config.gridCols) + '个字' : '输入一个汉字'}}"
        placeholder-class="input-placeholder"
      />
    </view>
		<view class="btn-settings" bind:tap="toggleSettings">
			<text>设置</text>
		</view>
    <view class="btn-export {{isExporting ? 'btn--disabled' : ''}}" bind:tap="onExport">
      <text>{{isExporting ? '导出中' : '导出'}}</text>
    </view>
  </view>

  <!-- 设置面板（双击唤起） -->
  <SettingsPanel visible="{{showSettings}}" title="九宫格设置" bindclose="closeSettings">
    <!-- 文字内容 -->
    <SetItemWrapper label="文字内容" fieldClass="input_wrapper">
      <van-field value="{{ config.text }}" bind:blur="onTextBlur" placeholder="{{config.multiMode ? '每格一字' : '输入一个汉字'}}" />
    </SetItemWrapper>

    <!-- 背景颜色 -->
    <SetItemWrapper label="背景颜色" fieldClass="slider_wrapper">
      <ColorPicker colorList="{{[config.bgColor]}}" bind:colorChange="onBgColorChange" />
    </SetItemWrapper>

    <!-- 文字颜色 -->
    <SetItemWrapper label="文字颜色" fieldClass="slider_wrapper">
      <ColorPicker colorList="{{[config.textColor]}}" bind:colorChange="onTextColorChange" />
    </SetItemWrapper>

    <!-- 网格线颜色 -->
    <SetItemWrapper label="网格线颜色" fieldClass="slider_wrapper">
      <ColorPicker colorList="{{[config.gridColor]}}" bind:colorChange="onGridColorChange" />
    </SetItemWrapper>

    <!-- 网格线宽 -->
    <SetItemWrapper label="网格线宽" fieldClass="slider_wrapper">
      <van-slider min="0" max="6" step="0.5" value="{{ config.gridWidth }}" use-button-slot bind:change="onGridWidthChange">
        <view class="custom-button" slot="button">{{ config.gridWidth }}</view>
      </van-slider>
    </SetItemWrapper>

    <!-- 文字加粗 -->
    <SetItemWrapper label="文字加粗" fieldClass="slider_wrapper">
      <van-switch checked="{{ config.fontWeight === 'bold' }}" bind:change="onFontWeightChange" />
    </SetItemWrapper>

    <!-- 字体大小 -->
    <SetItemWrapper label="字体大小" fieldClass="slider_wrapper">
      <van-slider min="40" max="95" step="5" value="{{ config.fontSize }}" use-button-slot bind:change="onFontSizeChange">
        <view class="custom-button" slot="button">{{ config.fontSize }}%</view>
      </van-slider>
    </SetItemWrapper>

    
    <!-- 字体选择 -->
    <view class="sep">字体</view>
    <view class="fonts" style="padding: 0 16px;">
      <view class="font-card {{!config.fontFamily ? 'font-card--on' : ''}}"
        bindtap="onFontSelect" data-font="">
        <text class="font-card__preview">默认</text>
      </view>
      <block wx:for="{{fontList}}" wx:for-item="f" wx:key="name">
        <view class="font-card {{config.fontFamily===f.name?'font-card--on':''}}"
          bindtap="onFontSelect" data-font="{{f.name}}">
          <text class="font-card__preview" style="font-family:{{f.name}}">{{f.previewText}}</text>
        </view>
      </block>
    </view>


    <!-- 发光开关 -->
    <SetItemWrapper label="发光效果" fieldClass="slider_wrapper">
      <van-switch checked="{{ config.glowEnabled }}" bind:change="onGlowEnabledChange" />
    </SetItemWrapper>

    <!-- 发光颜色（仅开启发光时显示） -->
    <block wx:if="{{ config.glowEnabled }}">
      <SetItemWrapper label="发光颜色" fieldClass="slider_wrapper">
        <ColorPicker colorList="{{[config.glowColor]}}" bind:colorChange="onGlowColorChange" />
      </SetItemWrapper>

      <SetItemWrapper label="发光强度" fieldClass="slider_wrapper">
        <van-slider min="5" max="40" step="1" value="{{ config.glowBlur }}" use-button-slot bind:change="onGlowBlurChange">
          <view class="custom-button" slot="button">{{ config.glowBlur }}px</view>
        </van-slider>
      </SetItemWrapper>
    </block>
  </SettingsPanel>

  
</view>
