page {
  background: #1a1a2e;
}

.page {
  height: 100vh;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.header {
  padding: 60rpx 24rpx 40rpx;
}

.header__title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section {
  margin: 32rpx 0;
}

.section__head {
  display: flex;
  align-items: center;
  padding: 0 8rpx 20rpx;
}

.section__bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0e8;
}

.section__grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: calc(50% - 12rpx);
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #252540;
  border-radius: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-sizing: border-box;
  transition: transform 0.15s ease;
}

.card--hover {
  transform: scale(0.96);
}

.card__icon {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.card__info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8e8f0;
  margin-bottom: 6rpx;
}

.card__desc {
  font-size: 22rpx;
  color: #7a8098;
  line-height: 1.3;
}

.footer {
  padding: 40rpx 24rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer__text {
  color: #555;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.footer__feedback {
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: #8890a8;
  background: transparent;
  border: 1rpx solid #3a3a55;
  border-radius: 32rpx;
  line-height: 1;
}

.footer__feedback::after {
  border: none;
}

/* ========== 原生模板广告容器 ========== */

.ad-container {
  width: 100%;
  margin: 24rpx 0;
  padding: 0 8rpx;
  box-sizing: border-box;
}

/* 广告组件自身样式覆盖（可选） */
.ad-container ad-custom {
  display: block;
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ========== 引导 tooltip ========== */

.guide-tip {
  position: fixed;
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  animation: tipFadeIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes tipFadeIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.guide-tip__arrow {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #fff;
  filter: drop-shadow(0 -2rpx 4rpx rgba(0,0,0,0.08));
}

.guide-tip__body {
  border-radius: 16rpx;
  padding: 4rpx;
  background: linear-gradient(270deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #845ef7, #ff6b6b);
  background-size: 400% 400%;
  animation: borderFlow 3s linear infinite;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.18);
}

@keyframes borderFlow {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.guide-tip__body-inner {
  background: #fff;
  border-radius: 13rpx;
  border: 3rpx dotted #4d96ff;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  white-space: nowrap;
}

.guide-tip__text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1;
  letter-spacing: 2rpx;
  animation: textBreathe 2s ease-in-out infinite;
}

@keyframes textBreathe {
  0%, 100% { text-shadow: 0 0 0rpx transparent; }
  50%      { text-shadow: 0 0 12rpx rgba(77, 150, 255, 0.6); }
}

.guide-tip__close {
  font-size: 28rpx;
  color: #bbb;
  padding: 0 4rpx;
  line-height: 1;
}

/* ========== 字体功能弹窗 ========== */
.font-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.font-modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  width: 560rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  animation: fontModalIn 0.3s ease;
}

@keyframes fontModalIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.font-modal__icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.font-modal__title {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.font-modal__desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.font-modal__btn {
  display: inline-block;
  padding: 18rpx 80rpx;
  background: linear-gradient(135deg, #667eea, #f093fb);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
}
