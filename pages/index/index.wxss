page {
  background: #1a1a2e;
}

.page {
  height: 100vh;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.header {
  padding: 60rpx 24rpx 40rpx;
}

.header__title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section {
  margin: 32rpx 0;
}

.section__head {
  display: flex;
  align-items: center;
  padding: 0 8rpx 20rpx;
}

.section__bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0e8;
}

.section__grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.card {
  width: calc(50% - 12rpx);
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #252540;
  border-radius: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-sizing: border-box;
  transition: transform 0.15s ease;
}

.card--hover {
  transform: scale(0.96);
}

.card__icon {
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.card__info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8e8f0;
  margin-bottom: 6rpx;
}

.card__desc {
  font-size: 22rpx;
  color: #7a8098;
  line-height: 1.3;
}

.footer {
  padding: 40rpx 24rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer__text {
  color: #555;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.footer__feedback {
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: #8890a8;
  background: transparent;
  border: 1rpx solid #3a3a55;
  border-radius: 32rpx;
  line-height: 1;
}

.footer__feedback::after {
  border: none;
}
