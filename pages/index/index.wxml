<scroll-view class="page" scroll-y>
  <!-- 引导 tooltip：箭头指向右上角 ··· -->
  <view class="guide-tip" wx:if="{{showGuide}}" style="top: {{0}}px; left: {{guideLeft-10}}px;">
    <view class="guide-tip__arrow" style="margin-left: {{arrowOffset}}px;"></view>
    <view class="guide-tip__body">
      <view class="guide-tip__body-inner">
        <text class="guide-tip__close" catchtap="onDismissGuide">✕</text>
        <text class="guide-tip__text">添加到我的小程序</text>
      </view>
    </view>
  </view>

  <view wx:for="{{categories}}" wx:key="title" class="section">
    <view class="section__head">
      <view class="section__bar" style="background: {{item.color}}"></view>
      <text class="section__title">{{item.title}}</text>
    </view>
    <view class="section__grid">
      <view
        wx:for="{{item.items}}"
        wx:key="name"
        wx:for-item="card"
        class="card"
        hover-class="card--hover"
        data-page="{{card.page}}"
        bindtap="onTapItem"
      >
        <view class="card__icon" style="background: {{item.color}}">
          <text>{{card.icon}}</text>
        </view>
        <view class="card__info">
          <text class="card__name">{{card.name}}</text>
          <text class="card__desc">{{card.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 在第二个分类（创意工具）后插入广告 -->
    <block wx:if="{{index === 1}}">
      <view class="ad-container">
        <ad-custom
          unit-id="adunit-b88b16a904e9f37a"
          bindload="onAdLoad"
          binderror="onAdError"
          bindclose="onAdClose"
        ></ad-custom>
      </view>
    </block>
  </view>

  <view class="footer">
    <text class="footer__text">更多工具开发中...</text>
    <button class="footer__feedback" open-type="feedback">意见建议</button>
  </view>
</scroll-view>

<!-- 字体功能弹窗 -->
<view class="font-modal-mask" wx:if="{{showFontModal}}" catchtap="onDismissFontModal">
  <view class="font-modal" catchtap="noop">
    <view class="font-modal__title">字体功能上线啦！！</view>
    <view class="font-modal__desc">
     <view> 单行滚动、多行滚动、九宫格切字,</view>
		 <view>现在都能选择字体了!</view>
		 <view>数十种个性字体! 快去试试吧!</view>
    </view>
    <view class="font-modal__btn" bindtap="onDismissFontModal">知道了</view>
  </view>
</view>