.color-list{
	display: flex;
	height: 100%;
	gap: 10rpx;
	align-items: center;
}
.color-item{
	height: 100%;
	width: 100%;
}
.color-option{
	width:60rpx;height:60rpx;padding:10rpx;
	margin:10rpx;
	border-radius: 10rpx;
	box-shadow: 0 0 10rpx rgba(0, 0, 0, 0.1);
	display: flex;
	justify-content: center;
	align-items: center;
}
.color_options{
	display:flex;
	flex-wrap: wrap;
	justify-content: space-around;
}